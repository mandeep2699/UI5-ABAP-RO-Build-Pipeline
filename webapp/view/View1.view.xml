<mvc:View
    controllerName="com.transports.transport.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"
>
    <Page
        id="page"
        title="Critical Object Maintenance Set"
    >
        <content>
            <Table
                inset="false"
                width="60%"
                items="{
			      path: 'TestModel>/Projects'
	        	}">
                <columns>
                    <Column width="12em">
                        <Text text="Obj Name" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                    >
                        <Text text="Pgmid" />
                    </Column>
                    <Column
                        minScreenWidth="Desktop"
                        demandPopin="true"
                        hAlign="End"
                    >
                        <Text text="Object" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem vAlign="Middle">
                        <cells>
                            <ObjectIdentifier text="{TestModel>ObjName}" />
                            <Text text="{TestModel>Pgmid}" />
                            <Text text="{TestModel>Object}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
